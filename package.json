{
  "name": "weevrbird",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android:preview": "npx eas-cli@latest build --platform android --profile preview",
    "build:android:production": "npx eas-cli@latest build --platform android --profile production",
    "build:ios:preview": "npx eas-cli@latest build --platform ios --profile preview",
    "build:ios:production": "npx eas-cli@latest build --platform ios --profile production",
    "submit:android:production": "npx eas-cli@latest submit --platform android --profile production",
    "submit:ios:production": "npx eas-cli@latest submit --platform ios --profile production",
    "check": "npm run typecheck && npm run check:app-state && npm run check:pasted-content && npm run check:copy && npm run check:legal && npm run check:content && npm run check:assets && npm run check:config",
    "check:app-state": "node scripts/check-app-state.cjs",
    "check:assets": "node scripts/check-assets.cjs",
    "check:config": "node scripts/check-app-config.cjs",
    "check:content": "node scripts/check-content-sources.cjs",
    "check:copy": "node scripts/check-copy.cjs",
    "check:legal": "node scripts/check-legal-docs.cjs",
    "check:pasted-content": "node scripts/check-pasted-content.cjs",
    "export:brand": "node scripts/export-brand-assets.mjs",
    "export:store-screenshots": "node scripts/export-store-screenshots.mjs",
    "release:next:android": "node scripts/bump-build-number.cjs android --dry-run",
    "release:next:ios": "node scripts/bump-build-number.cjs ios --dry-run",
    "release:next:all": "node scripts/bump-build-number.cjs all --dry-run",
    "release:bump:android": "node scripts/bump-build-number.cjs android",
    "release:bump:ios": "node scripts/bump-build-number.cjs ios",
    "release:bump:all": "node scripts/bump-build-number.cjs all",
    "release:preflight": "npm run check && npm run release:status",
    "release:status": "node scripts/release-status.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-build-properties": "~0.13.3",
    "expo-clipboard": "~7.0.1",
    "expo-font": "~13.0.4",
    "expo-linear-gradient": "~14.0.2",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "sharp": "^0.35.3",
    "typescript": "^5.6.3"
  }
}
