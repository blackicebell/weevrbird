{
  "expo": {
    "name": "Weevrbird",
    "slug": "weevrbird",
    "version": "0.1.0",
    "description": "A personal information app for finite daily editions, Smartfeeds, saved context, and useful contributions.",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "weevrbird",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFDF8"
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.weevrbird.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.weevrbird.app",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4EFE6"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1cc9f8e4-96a8-4d29-b644-02e6a9cf1688"
      }
    },
    "owner": "blackicebell"
  }
}
